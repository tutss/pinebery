{
  "manifest_version": 3,
  "name": "Pinebery",
  "version": "1.3.0",
  "description": "Tree-style vertical tabs in Chrome's side panel",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel",
    "favicon"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_page": "src/options/index.html",
  "action": {
    "default_title": "Pinebery",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  }
}
